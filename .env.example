# Anthropic API — required for all pipeline stages
ANTHROPIC_API_KEY=your_key_here

# HackerOne REST API — optional, enriches KB with CVE/bounty data
H1_API_USER=your_h1_username
H1_API_TOKEN=your_h1_api_token

# Elysium KB path — used by kb_ingest.py and kb_mcp_server.py on Elysium
HACKER_KB_DIR=/sanctum/hacker-kb
